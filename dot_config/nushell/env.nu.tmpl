{{ if eq .chezmoi.os "freebsd" }}
$env.EDITOR = 'hx'
$env.PAGER = 'less'
$env.BLOCKSIZE = 'K'
$env.LANG = 'C.UTF-8'
$env.MM_CHARSET = 'UTF-8'
$env.PATH = [
  /sbin
  /bin
  /usr/sbin
  /usr/bin
  /usr/local/sbin
  /usr/local/bin
  $"($env.HOME)/bin"
]
$env.MAIL = '/var/mail/robert'
$env.SHELL = '/usr/local/bin/nu'
{{- end }}
